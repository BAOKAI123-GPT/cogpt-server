# 复制为 .env 并填入真实值（.env 不进 git，仅服务器持有）
PUBLIC_BASE_URL="https://cogpt.art"
JWT_SECRET="改成一长串随机字符串"

# 管理员后台初始账号（首次启动用 npm run seed 写入）
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="改成强密码"

# 阿里云短信（PNVS dypnsapi）—— 见 docs/阿里云短信验证码接入手册
ALIYUN_SMS_ACCESS_KEY_ID=""
ALIYUN_SMS_ACCESS_KEY_SECRET=""

# zpay 易支付 —— 见 docs/zpay易支付接入手册
ZPAY_PID=""
ZPAY_KEY=""

# 中转站（也可在管理员后台填写，存数据库 Config，优先用后台值）
RELAY_BASE_URL=""
RELAY_API_KEY=""
