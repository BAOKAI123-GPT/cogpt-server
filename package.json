{
  "name": "cogpt-server",
  "version": "0.1.0",
  "private": true,
  "description": "cogpt 后端 — 短信登录 + 会员/额度 + 生图代理 + zpay 支付 + 管理员后台",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "prisma generate && next build",
    "start": "next start -H 127.0.0.1 -p 3000",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "seed": "node --import tsx scripts/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@alicloud/dypnsapi20170525": "2.0.0",
    "@alicloud/openapi-client": "^0.4.15",
    "@prisma/client": "6.19.3",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "next": "15.5.19",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "^0.35.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.17.12",
    "@types/qrcode": "^1.5.5",
    "@types/react": "19.2.17",
    "prisma": "6.19.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
